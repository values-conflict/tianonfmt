		{
			"type": "RUN",
			"form": "shell",
			"args": "set -e;     export $(curl -s ${PLATFORM_WEBROOT}/latest-build.yml | grep 'download:' | sed 's/:[^:\\/\\/]/=/g')     \u0026\u0026 export $(curl -s ${PLATFORM_WEBROOT}/latest-build.yml | grep 'download_signature:' | sed 's/:[^:\\/\\/]/=/g')     \u0026\u0026 export DOWNLOAD_DIR=$(echo $download | sed \"s/-${OS_VER}.tar.gz//g\")     \u0026\u0026 echo $DOWNLOAD_DIR \u003e .swift_tag     \u0026\u0026 export GNUPGHOME=\"$(mktemp -d)\"     \u0026\u0026 curl -fsSL ${PLATFORM_WEBROOT}/${DOWNLOAD_DIR}/${download} -o latest_toolchain.tar.gz         ${PLATFORM_WEBROOT}/${DOWNLOAD_DIR}/${download_signature} -o latest_toolchain.tar.gz.sig     \u0026\u0026 curl -fSsL --compressed https://swift.org/keys/all-keys.asc | gpg --import -     \u0026\u0026 gpg --batch --verify latest_toolchain.tar.gz.sig latest_toolchain.tar.gz     \u0026\u0026 tar -xzf latest_toolchain.tar.gz --directory / --strip-components=1     \u0026\u0026 chmod -R o+r /usr/lib/swift     \u0026\u0026 rm -rf \"$GNUPGHOME\" latest_toolchain.tar.gz.sig latest_toolchain.tar.gz     \u0026\u0026 apt-get purge --auto-remove -y curl",
			"lines": [
				{
					"kind": "instruction",
					"text": "RUN set -e; \\"
				},
				{
					"kind": "continuation",
					"text": "    export $(curl -s ${PLATFORM_WEBROOT}/latest-build.yml | grep 'download:' | sed 's/:[^:\\/\\/]/=/g')  \\"
				},
				{
					"kind": "continuation",
					"text": "    \u0026\u0026 export $(curl -s ${PLATFORM_WEBROOT}/latest-build.yml | grep 'download_signature:' | sed 's/:[^:\\/\\/]/=/g')  \\"
				},
				{
					"kind": "continuation",
					"text": "    \u0026\u0026 export DOWNLOAD_DIR=$(echo $download | sed \"s/-${OS_VER}.tar.gz//g\") \\"
				},
				{
					"kind": "continuation",
					"text": "    \u0026\u0026 echo $DOWNLOAD_DIR \u003e .swift_tag \\"
				},
				{
					"kind": "comment",
					"text": "    # - Download the GPG keys, Swift toolchain, and toolchain signature, and verify."
				},
				{
					"kind": "continuation",
					"text": "    \u0026\u0026 export GNUPGHOME=\"$(mktemp -d)\" \\"
				},
				{
					"kind": "continuation",
					"text": "    \u0026\u0026 curl -fsSL ${PLATFORM_WEBROOT}/${DOWNLOAD_DIR}/${download} -o latest_toolchain.tar.gz \\"
				},
				{
					"kind": "continuation",
					"text": "        ${PLATFORM_WEBROOT}/${DOWNLOAD_DIR}/${download_signature} -o latest_toolchain.tar.gz.sig \\"
				},
				{
					"kind": "continuation",
					"text": "    \u0026\u0026 curl -fSsL --compressed https://swift.org/keys/all-keys.asc | gpg --import -  \\"
				},
				{
					"kind": "continuation",
					"text": "    \u0026\u0026 gpg --batch --verify latest_toolchain.tar.gz.sig latest_toolchain.tar.gz \\"
				},
				{
					"kind": "comment",
					"text": "    # - Unpack the toolchain, set libs permissions, and clean up."
				},
				{
					"kind": "continuation",
					"text": "    \u0026\u0026 tar -xzf latest_toolchain.tar.gz --directory / --strip-components=1 \\"
				},
				{
					"kind": "continuation",
					"text": "    \u0026\u0026 chmod -R o+r /usr/lib/swift \\"
				},
				{
					"kind": "continuation",
					"text": "    \u0026\u0026 rm -rf \"$GNUPGHOME\" latest_toolchain.tar.gz.sig latest_toolchain.tar.gz \\"
				},
				{
					"kind": "continuation",
					"text": "    \u0026\u0026 apt-get purge --auto-remove -y curl"
				}
