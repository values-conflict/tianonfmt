																			"[",
																			"-n",
																			"\"${NEXTCLOUD_TRUSTED_DOMAINS+x}\"",
																			"]"
																		]
																	}
																],
																"then": [
																	{
																		"type": "call",
																		"args": [
																			"echo",
																			"\"Setting trusted domains…\""
																		]
																	},
																	{
																		"type": "call",
																		"args": [
																			"set",
																			"-f"
																		]
																	},
																	{
																		"type": "call",
																		"assigns": [
																			"NC_TRUSTED_DOMAIN_IDX=1"
																		],
																		"args": []
																	},
																	{
																		"type": "for",
																		"loop": {
																			"type": "wordIter",
																			"name": "DOMAIN",
																			"items": [
																				"${NEXTCLOUD_TRUSTED_DOMAINS}"
																			]
																		},
																		"do": [
																			{
																				"type": "call",
																				"assigns": [
																					"DOMAIN=$(echo \"${DOMAIN}\" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
																				],
																				"args": []
																			},
																			{
																				"type": "call",
																				"args": [
																					"run_as",
																					"\"php /var/www/html/occ config:system:set trusted_domains $NC_TRUSTED_DOMAIN_IDX --value=\\\"${DOMAIN}\\\"\""
																				]
																			},
																			{
																				"type": "call",
																				"assigns": [
																					"NC_TRUSTED_DOMAIN_IDX=$((NC_TRUSTED_DOMAIN_IDX + 1))"
																				],
																				"args": []
																			}
																		]
																	},
																	{
																		"type": "call",
																		"args": [
																			"set",
																			"+f"
																		]
																	}
																]
															},
															{
																"type": "call",
																"args": [
																	"run_path",
																	"post-installation"
																]
															}
														]
													}
												]
											},
											{
												"type": "if",
												"cond": [
													{
														"type": "call",
														"args": [
															"[",
															"\"$install\"",
															"=",
															"false",
															"]"
														]
													}
												],
												"then": [
													{
														"type": "call",
														"args": [
															"echo",
															"\"Next step: Access your instance to finish the web-based installation!\""
														]
													},
													{
														"type": "call",
														"args": [
															"echo",
															"\"Hint: You can specify NEXTCLOUD_ADMIN_USER and NEXTCLOUD_ADMIN_PASSWORD and the database variables _prior to first launch_ to fully automate initial installation.\""
														]
													}
												]
											}
										],
										"else": [
											{
												"type": "call",
												"args": [
													"run_path",
													"pre-upgrade"
												]
											},
											{
												"type": "call",
												"args": [
													"run_as",
													"'php /var/www/html/occ upgrade'"
												]
											},
											{
												"type": "stmt",
												"cmd": {
													"type": "call",
													"args": [
														"get_enabled_apps"
													]
												},
												"redirs": [
													{
														"op": "\u003e",
														"word": "/tmp/list_after"
													}
												]
											},
											{
												"type": "call",
												"assigns": [
													"disabled_apps=\"$(comm -23 /tmp/list_before /tmp/list_after || true)\""
												],
												"args": []
											},
											{
												"type": "if",
												"cond": [
													{
														"type": "call",
														"args": [
															"[",
															"-n",
															"\"$disabled_apps\"",
															"]"
														]
													}
												],
												"then": [
													{
														"type": "call",
														"args": [
															"echo",
															"\"The following apps have been disabled:\""
														]
													},
													{
														"type": "call",
														"args": [
															"printf",
															"'%s\\n'",
															"\"$disabled_apps\""
														]
													}
												]
											},
											{
												"type": "call",
												"args": [
													"rm",
													"-f",
													"/tmp/list_before",
													"/tmp/list_after"
												]
											},
											{
												"type": "call",
												"args": [
													"run_path",
													"post-upgrade"
												]
											}
										]
									},
									{
										"type": "call",
										"args": [
											"echo",
											"\"Initializing finished\""
										]
									}
								]
							},
							{
								"type": "if",
								"cond": [
									{
										"type": "binary",
										"op": "\u0026\u0026",
										"x": {
											"type": "call",
											"args": [
												"[",
												"-n",
												"\"${NEXTCLOUD_INIT_HTACCESS+x}\"",
												"]"
											]
										},
										"y": {
											"type": "call",
											"args": [
												"[",
												"\"$installed_version\"",
												"!=",
												"\"0.0.0.0\"",
												"]"
											]
										}
									}
								],
								"then": [
									{
										"type": "call",
										"args": [
											"run_as",
											"'php /var/www/html/occ maintenance:update:htaccess'"
										]
									}
								]
							}
						]
					},
					"redirs": [
						{
							"op": "\u003e",
							"word": "/var/www/html/nextcloud-init-sync.lock",
							"n": "9"
						}
					]
				},
				{
					"type": "for",
					"loop": {
						"type": "wordIter",
						"name": "cfgPath",
						"items": [
							"/usr/src/nextcloud/config/*.php"
						]
					},
					"do": [
						{
							"type": "call",
							"assigns": [
								"cfgFile=$(basename \"$cfgPath\")"
							],
							"args": []
						},
						{
							"type": "if",
							"cond": [
								{
									"type": "binary",
									"op": "\u0026\u0026",
									"x": {
										"type": "call",
										"args": [
											"[",
											"\"$cfgFile\"",
											"!=",
											"\"config.sample.php\"",
											"]"
										]
									},
									"y": {
										"type": "call",
										"args": [
											"[",
											"\"$cfgFile\"",
											"!=",
											"\"autoconfig.php\"",
											"]"
										]
									}
								}
							],
							"then": [
								{
									"type": "if",
									"cond": [
										{
											"type": "stmt",
											"cmd": {
												"type": "call",
												"args": [
													"cmp",
													"-s",
													"\"/usr/src/nextcloud/config/$cfgFile\"",
													"\"/var/www/html/config/$cfgFile\""
												]
											},
											"negated": true
										}
									],
									"then": [
										{
											"type": "call",
											"args": [
												"echo",
												"\"Warning: /var/www/html/config/$cfgFile differs from the latest version of this image at /usr/src/nextcloud/config/$cfgFile\""
											]
										}
									]
								}
							]
						}
					]
				},
				{
					"type": "call",
					"args": [
						"run_path",
						"before-starting"
					]
				}
			]
		},
		{
			"type": "call",
			"args": [
				"exec",
				"\"$@\""
			]
		}
	]
}
