																]
															},
															{
																"cond": [
																	{
																		"type": "binary",
																		"op": "\u0026\u0026",
																		"x": {
																			"type": "binary",
																			"op": "\u0026\u0026",
																			"x": {
																				"type": "binary",
																				"op": "\u0026\u0026",
																				"x": {
