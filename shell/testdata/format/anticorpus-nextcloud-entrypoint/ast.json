															},
															{
																"type": "call",
																"args": [
																	"echo",
																	"\"Starting nextcloud installation\""
																]
															},
															{
																"type": "call",
																"assigns": [
																	"max_retries=10"
																],
																"args": []
															},
															{
																"type": "call",
																"assigns": [
																	"try=0"
																],
																"args": []
															},
															{
																"type": "until",
																"cond": [
																	{
																		"type": "binary",
																		"op": "||",
																		"x": {
																			"type": "call",
																			"args": [
																				"[",
																				"\"$try\"",
																				"-gt",
																				"\"$max_retries\"",
																				"]"
																			]
																		},
																		"y": {
																			"type": "call",
																			"args": [
																				"run_as",
