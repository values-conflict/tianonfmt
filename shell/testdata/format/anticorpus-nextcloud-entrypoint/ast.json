{
	"type": "shell",
	"file": "input.sh",
	"stmts": [
		{
			"type": "call",
			"args": [
				"set",
				"-eu"
			]
		},
		{
			"type": "funcDecl",
			"name": "version_greater",
			"body": {
				"type": "block",
				"stmts": [
					{
						"type": "call",
						"args": [
							"[",
							"\"$(printf '%s\\n' \"$@\" | sort -t '.' -n -k1,1 -k2,2 -k3,3 -k4,4 | head -n 1)\"",
							"!=",
							"\"$1\"",
							"]"
						]
					}
				]
			}
		},
		{
			"type": "funcDecl",
			"name": "directory_empty",
			"body": {
				"type": "block",
				"stmts": [
					{
						"type": "call",
						"args": [
							"[",
							"-z",
							"\"$(ls -A \"$1/\")\"",
							"]"
						]
					}
				]
			}
		},
		{
			"type": "funcDecl",
			"name": "run_as",
			"body": {
				"type": "block",
				"stmts": [
					{
						"type": "if",
						"cond": [
							{
								"type": "call",
								"args": [
									"[",
									"\"$(id -u)\"",
									"=",
									"0",
									"]"
								]
							}
						],
						"then": [
							{
								"type": "call",
								"args": [
									"su",
									"-p",
									"\"$user\"",
									"-s",
									"/bin/sh",
									"-c",
									"\"$1\""
								]
							}
						],
						"else": [
							{
								"type": "call",
								"args": [
									"sh",
									"-c",
									"\"$1\""
								]
							}
						]
					}
				]
			}
		},
		{
			"type": "funcDecl",
			"name": "run_path",
			"body": {
				"type": "block",
				"stmts": [
					{
						"type": "call",
						"args": [
							"local",
							"hook_folder_path=\"/docker-entrypoint-hooks.d/$1\""
						]
					},
					{
						"type": "call",
						"args": [
							"local",
							"found=0"
						]
					},
					{
						"type": "call",
						"args": [
							"echo",
							"\"=\u003e Searching for hook scripts (*.sh) to run, located in the folder \\\"${hook_folder_path}\\\"\""
						]
					},
					{
						"type": "if",
						"cond": [
							{
								"type": "binary",
								"op": "||",
								"x": {
									"type": "stmt",
									"cmd": {
										"type": "call",
										"args": [
											"[",
											"-d",
											"\"${hook_folder_path}\"",
											"]"
										]
									},
									"negated": true
								},
								"y": {
									"type": "call",
									"args": [
										"directory_empty",
										"\"${hook_folder_path}\""
									]
								}
							}
						],
						"then": [
							{
								"type": "call",
								"args": [
									"echo",
									"\"==\u003e Skipped: the \\\"$1\\\" folder is empty (or does not exist)\""
								]
							},
							{
								"type": "call",
								"args": [
									"return",
									"0"
								]
							}
						]
					},
					{
						"type": "binary",
						"op": "|",
						"x": {
							"type": "binary",
							"op": "|",
							"x": {
								"type": "call",
								"args": [
									"find",
									"\"${hook_folder_path}\"",
									"-maxdepth",
									"1",
									"-iname",
									"'*.sh'",
									"'('",
									"-type",
									"f",
									"-o",
									"-type",
									"l",
									"')'",
									"-print"
								]
							},
							"y": {
								"type": "call",
								"args": [
									"sort"
								]
							}
						},
						"y": {
							"type": "subshell",
							"stmts": [
								{
									"type": "while",
									"cond": [
										{
											"type": "call",
											"args": [
												"read",
												"-r",
												"script_file_path"
											]
										}
									],
									"do": [
										{
											"type": "if",
											"cond": [
												{
													"type": "stmt",
													"cmd": {
														"type": "call",
														"args": [
															"[",
															"-x",
															"\"${script_file_path}\"",
															"]"
														]
													},
													"negated": true
												}
											],
											"then": [
												{
													"type": "call",
													"args": [
														"echo",
														"\"==\u003e The script \\\"${script_file_path}\\\" was skipped, because it lacks the executable flag\""
													]
												},
												{
													"type": "call",
													"args": [
														"continue"
													]
												}
											]
										},
										{
											"type": "call",
											"args": [
												"echo",
												"\"==\u003e Running the script (cwd: $(pwd)): \\\"${script_file_path}\\\"\""
											]
										},
										{
											"type": "call",
											"assigns": [
												"found=$((found + 1))"
											],
											"args": []
										},
										{
											"type": "binary",
											"op": "||",
											"x": {
												"type": "call",
												"args": [
													"run_as",
													"\"${script_file_path}\""
												]
											},
											"y": {
												"type": "block",
												"stmts": [
													{
														"type": "call",
														"assigns": [
															"return_code=\"$?\""
														],
														"args": []
													},
													{
														"type": "call",
														"args": [
															"echo",
															"\"==\u003e Failed at executing script \\\"${script_file_path}\\\". Exit code: ${return_code}\""
														]
													},
													{
														"type": "call",
														"args": [
															"exit",
															"1"
														]
													}
												]
											}
										},
										{
											"type": "call",
											"args": [
												"echo",
												"\"==\u003e Finished executing the script: \\\"${script_file_path}\\\"\""
											]
										}
									]
								},
								{
									"type": "if",
									"cond": [
										{
											"type": "call",
											"args": [
												"[",
												"\"$found\"",
												"-gt",
												"\"0\"",
												"]"
											]
										}
									],
									"then": [
										{
											"type": "call",
											"args": [
												"echo",
												"\"=\u003e Completed executing scripts in the \\\"$1\\\" folder\""
											]
										}
									],
									"else": [
										{
											"type": "call",
											"args": [
												"echo",
												"\"==\u003e Skipped: the \\\"$1\\\" folder does not contain any valid scripts\""
											]
										}
									]
								}
							]
						}
					}
				]
			}
		},
		{
			"type": "funcDecl",
			"name": "file_env",
			"body": {
				"type": "block",
				"stmts": [
					{
						"type": "call",
						"args": [
							"local",
							"var=\"$1\""
						]
					},
					{
						"type": "call",
						"args": [
							"local",
							"fileVar=\"${var}_FILE\""
						]
					},
					{
						"type": "call",
						"args": [
							"local",
							"def=\"${2:-}\""
						]
					},
					{
						"type": "call",
						"args": [
							"local",
							"varValue=$(env | grep -E \"^${var}=\" | sed -E -e \"s/^${var}=//\")"
						]
					},
					{
						"type": "call",
						"args": [
							"local",
							"fileVarValue=$(env | grep -E \"^${fileVar}=\" | sed -E -e \"s/^${fileVar}=//\")"
						]
					},
					{
						"type": "if",
						"cond": [
							{
								"type": "binary",
								"op": "\u0026\u0026",
								"x": {
									"type": "call",
									"args": [
										"[",
										"-n",
										"\"${varValue}\"",
										"]"
									]
								},
								"y": {
									"type": "call",
									"args": [
										"[",
										"-n",
										"\"${fileVarValue}\"",
										"]"
									]
								}
							}
						],
						"then": [
							{
								"type": "stmt",
								"cmd": {
									"type": "call",
									"args": [
										"echo",
										"\"error: both $var and $fileVar are set (but are exclusive)\""
									]
								},
								"redirs": [
									{
										"op": "\u003e\u0026",
										"word": "2"
									}
								]
							},
							{
								"type": "call",
								"args": [
									"exit",
									"1"
								]
							}
						]
					},
					{
						"type": "if",
						"cond": [
							{
								"type": "call",
								"args": [
									"[",
									"-n",
									"\"${varValue}\"",
									"]"
								]
							}
						],
						"then": [
							{
								"type": "call",
								"args": [
									"export",
									"\"$var\"=\"${varValue}\""
								]
							}
						],
						"elifs": [
							{
								"cond": [
									{
										"type": "call",
										"args": [
											"[",
											"-n",
											"\"${fileVarValue}\"",
											"]"
										]
									}
								],
								"then": [
									{
										"type": "call",
										"args": [
											"export",
											"\"$var\"=\"$(cat \"${fileVarValue}\")\""
										]
									}
								]
							},
							{
								"cond": [
									{
										"type": "call",
										"args": [
											"[",
											"-n",
											"\"${def}\"",
											"]"
										]
									}
								],
								"then": [
									{
										"type": "call",
										"args": [
											"export",
											"\"$var\"=\"$def\""
										]
									}
								]
							}
						]
					},
					{
						"type": "call",
						"args": [
							"unset",
							"\"$fileVar\""
						]
					}
				]
			}
		},
		{
			"type": "funcDecl",
			"name": "get_enabled_apps",
			"body": {
				"type": "block",
				"stmts": [
					{
						"type": "binary",
						"op": "|",
						"x": {
							"type": "binary",
							"op": "|",
							"x": {
								"type": "binary",
								"op": "|",
								"x": {
									"type": "binary",
									"op": "|",
									"x": {
										"type": "call",
										"args": [
											"run_as",
											"'php /var/www/html/occ app:list'"
										]
									},
									"y": {
										"type": "call",
										"args": [
											"sed",
											"-n",
											"'/^Enabled:$/,/^Disabled:$/p'"
										]
									}
								},
								"y": {
									"type": "call",
									"args": [
										"sed",
										"'1d;$d'"
									]
								}
							},
							"y": {
								"type": "call",
								"args": [
									"sed",
									"-n",
									"'s/^  - \\([^:]*\\):.*/\\1/p'"
								]
							}
						},
						"y": {
							"type": "call",
							"args": [
								"sort"
							]
						}
					}
				]
			}
		},
		{
			"type": "funcDecl",
			"name": "configure_redis_session",
			"body": {
				"type": "block",
				"stmts": [
					{
						"type": "call",
						"args": [
							"local",
							"redis_save_path"
						]
					},
					{
						"type": "call",
						"args": [
							"local",
							"redis_auth=''"
						]
					},
					{
						"type": "call",
						"args": [
							"echo",
							"\"=\u003e Configuring PHP session handler...\""
						]
					},
					{
						"type": "if",
						"cond": [
							{
								"type": "call",
								"args": [
									"[",
									"-z",
									"\"${REDIS_HOST:-}\"",
									"]"
								]
							}
						],
						"then": [
							{
								"type": "call",
								"args": [
									"echo",
									"\"==\u003e Using default PHP session handler\""
								]
							},
							{
								"type": "call",
								"args": [
									"return",
									"0"
								]
							}
						]
					},
					{
						"type": "call",
						"args": [
							"file_env",
							"REDIS_HOST_PASSWORD"
						]
					},
					{
						"type": "case",
						"word": "\"$REDIS_HOST\"",
						"items": [
							{
								"patterns": [
									"/*"
								],
								"stmts": [
									{
										"type": "call",
										"assigns": [
											"redis_save_path=\"unix://${REDIS_HOST}\""
										],
										"args": []
									}
								]
							},
							{
								"patterns": [
									"*"
								],
								"stmts": [
									{
										"type": "call",
										"assigns": [
											"redis_save_path=\"tcp://${REDIS_HOST}:${REDIS_HOST_PORT:=6379}\""
										],
										"args": []
									}
								]
							}
						]
					},
					{
						"type": "if",
						"cond": [
							{
								"type": "binary",
								"op": "\u0026\u0026",
								"x": {
									"type": "call",
									"args": [
										"[",
										"-n",
										"\"${REDIS_HOST_PASSWORD+x}\"",
										"]"
									]
								},
								"y": {
									"type": "call",
									"args": [
										"[",
										"-n",
										"\"${REDIS_HOST_USER+x}\"",
										"]"
									]
								}
							}
						],
						"then": [
							{
								"type": "call",
								"assigns": [
									"redis_auth=\"?auth[]=${REDIS_HOST_USER}\u0026auth[]=${REDIS_HOST_PASSWORD}\""
								],
								"args": []
							}
						],
						"elifs": [
							{
								"cond": [
									{
										"type": "call",
										"args": [
											"[",
											"-n",
											"\"${REDIS_HOST_PASSWORD+x}\"",
											"]"
										]
									}
								],
								"then": [
									{
										"type": "call",
										"assigns": [
											"redis_auth=\"?auth=${REDIS_HOST_PASSWORD}\""
										],
										"args": []
									}
								]
							}
						]
					},
					{
						"type": "call",
						"args": [
							"echo",
							"\"==\u003e Using Redis as PHP session handler...\""
						]
					},
					{
						"type": "stmt",
						"cmd": {
							"type": "block",
							"stmts": [
								{
									"type": "call",
									"args": [
										"echo",
										"'session.save_handler = redis'"
									]
								},
								{
									"type": "call",
									"args": [
										"echo",
										"\"session.save_path = \\\"${redis_save_path}${redis_auth}\\\"\""
									]
								},
								{
									"type": "call",
									"args": [
										"echo",
										"\"redis.session.locking_enabled = 1\""
									]
								},
								{
									"type": "call",
									"args": [
										"echo",
										"\"redis.session.lock_retries = -1\""
									]
								},
								{
									"type": "call",
									"args": [
										"echo",
										"\"redis.session.lock_wait_time = 10000\""
									]
								}
							]
						},
						"redirs": [
							{
								"op": "\u003e",
								"word": "/usr/local/etc/php/conf.d/redis-session.ini"
							}
						]
					}
				]
			}
		},
		{
			"type": "if",
			"cond": [
				{
					"type": "stmt",
					"cmd": {
						"type": "call",
						"args": [
							"expr",
							"\"$1\"",
							":",
							"\"apache\""
						]
					},
					"redirs": [
						{
							"op": "\u003e",
							"word": "/dev/null",
							"n": "1"
						}
					]
				}
			],
			"then": [
				{
					"type": "if",
					"cond": [
						{
							"type": "call",
							"args": [
								"[",
								"-n",
								"\"${APACHE_DISABLE_REWRITE_IP+x}\"",
								"]"
							]
						}
					],
					"then": [
						{
							"type": "call",
							"args": [
								"a2disconf",
								"remoteip"
							]
						}
					]
				}
			]
		},
		{
			"type": "if",
			"cond": [
				{
					"type": "binary",
					"op": "||",
					"x": {
						"type": "binary",
						"op": "||",
						"x": {
							"type": "stmt",
							"cmd": {
								"type": "call",
								"args": [
									"expr",
									"\"$1\"",
									":",
									"\"apache\""
								]
							},
							"redirs": [
								{
									"op": "\u003e",
									"word": "/dev/null",
									"n": "1"
								}
							]
						},
						"y": {
							"type": "call",
							"args": [
								"[",
								"\"$1\"",
								"=",
								"\"php-fpm\"",
								"]"
							]
						}
					},
					"y": {
						"type": "call",
						"args": [
							"[",
							"\"${NEXTCLOUD_UPDATE:-0}\"",
							"-eq",
							"1",
							"]"
						]
					}
				}
			],
			"then": [
				{
					"type": "call",
					"assigns": [
						"uid=\"$(id -u)\""
					],
					"args": []
				},
				{
					"type": "call",
					"assigns": [
						"gid=\"$(id -g)\""
					],
					"args": []
				},
				{
					"type": "if",
					"cond": [
						{
							"type": "call",
							"args": [
								"[",
								"\"$uid\"",
								"=",
								"'0'",
								"]"
							]
						}
					],
					"then": [
						{
							"type": "case",
							"word": "\"$1\"",
							"items": [
								{
									"patterns": [
										"apache2*"
									],
									"stmts": [
										{
											"type": "call",
											"assigns": [
												"user=\"${APACHE_RUN_USER:-www-data}\""
											],
											"args": []
										},
										{
											"type": "call",
											"assigns": [
												"group=\"${APACHE_RUN_GROUP:-www-data}\""
											],
											"args": []
										},
										{
											"type": "call",
											"assigns": [
												"user=\"${user#'#'}\""
											],
											"args": []
										},
										{
											"type": "call",
											"assigns": [
												"group=\"${group#'#'}\""
											],
											"args": []
										}
									]
								},
								{
									"patterns": [
										"*"
									],
									"stmts": [
										{
											"type": "call",
											"assigns": [
												"user='www-data'"
											],
											"args": []
										},
										{
											"type": "call",
