{
	"type": "shell",
	"file": "input.sh",
	"stmts": [
		{
			"type": "call",
			"args": [
				"set",
				"-Eeuo",
				"pipefail"
			]
		},
		{
			"type": "call",
			"assigns": [
				"json=\"$(jq -n --arg foo \"bar\" '{\"foo\": $foo}')\""
			],
			"args": []
		},
		{
			"type": "call",
			"assigns": [
				"result=\"$(jq -r '.foo' \u003c\u003c\u003c\"$json\")\""
			],
			"args": []
		},
		{
			"type": "call",
			"args": [
				"echo",
				"\"$result\""
			]
		}
	]
}
